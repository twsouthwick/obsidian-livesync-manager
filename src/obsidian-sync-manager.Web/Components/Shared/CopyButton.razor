@inject IJSRuntime JS

<FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small" @onclick="CopyToClipboard"
              Title="Copy to clipboard"
              IconStart="@(copied ? new Icons.Regular.Size16.Checkmark() : new Icons.Regular.Size16.Copy())">
    @(copied ? CopiedLabel : Label)
</FluentButton>

@code {
    private bool copied;

    [Parameter, EditorRequired] public string Text { get; set; } = default!;
    [Parameter] public string Label { get; set; } = "Copy";
    [Parameter] public string CopiedLabel { get; set; } = "Copied!";

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Text);
        copied = true;
        StateHasChanged();

        await Task.Delay(2000);
        copied = false;
        StateHasChanged();
    }
}
