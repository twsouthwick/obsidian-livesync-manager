@rendermode InteractiveServer
@inject IJSRuntime JS

<button class="btn btn-sm @ButtonClass" @onclick="CopyToClipboard" title="Copy to clipboard">
    @if (copied)
    {
        <span class="bi bi-check-lg" aria-hidden="true"></span> @CopiedLabel
    }
    else
    {
        <span class="bi bi-clipboard" aria-hidden="true"></span> @Label
    }
</button>

@code {
    private bool copied;

    [Parameter, EditorRequired] public string Text { get; set; } = default!;
    [Parameter] public string Label { get; set; } = "Copy";
    [Parameter] public string CopiedLabel { get; set; } = "Copied!";
    [Parameter] public string ButtonClass { get; set; } = "btn-outline-secondary";

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Text);
        copied = true;
        StateHasChanged();

        await Task.Delay(2000);
        copied = false;
        StateHasChanged();
    }
}
