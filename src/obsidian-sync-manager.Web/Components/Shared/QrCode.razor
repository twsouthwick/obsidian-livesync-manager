<div style="text-align: center; margin: 1rem 0; padding: 1rem; border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; background: white;">
    @((MarkupString)SetupUriEncryptionService.GenerateQrCodeSvg(Uri))
    @if (Caption is not null)
    {
        <p style="font-size: 0.85rem; color: var(--neutral-foreground-hint); margin-top: 0.5rem;">@Caption</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Uri { get; set; } = default!;
    [Parameter] public string? Caption { get; set; }
}
