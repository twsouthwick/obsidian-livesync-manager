@page "/workspaces/{Id}"
@inject WorkspaceService WorkspaceSvc
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@(workspace?.Name ?? Id) — Workspace</PageTitle>

<FluentBreadcrumb Style="margin-bottom: 1rem;">
    <FluentBreadcrumbItem Href="workspaces">Workspaces</FluentBreadcrumbItem>
    <FluentBreadcrumbItem>@(workspace?.Name ?? Id)</FluentBreadcrumbItem>
</FluentBreadcrumb>

@if (!found.HasValue)
{
    <FluentProgress />
}
else if (!found.Value)
{
    <EmptyState Title="Workspace not found" Icon="@(new Icons.Regular.Size48.Warning())">
        The workspace does not exist or you don't have access.
    </EmptyState>
}
else
{
    <h1 style="margin-bottom: 1.5rem;">@workspace!.Name</h1>

    <FluentTabs @bind-ActiveTabId="activeTab" Style="min-height: 400px;">
        <FluentTab Label="Setup" Id="tab-setup" Icon="@(new Icons.Regular.Size20.PlugConnected())">
            <FluentStack Orientation="Orientation.Vertical" Wrap="true"
                         Style="gap: 1.5rem; margin-top: 1rem; align-items: stretch;">
                <div style="flex: 1; min-width: 300px;">
                    <ConnectionInfoCard DatabaseName="@workspace.DatabaseName" CouchDbUsername="@username" />
                </div>
                <div style="flex: 1; min-width: 300px;">
                    <SetupUriCard Name="@workspace.Name" Username="@username" Sub="@sub"
                                  WorkspaceId="@Id" DatabaseName="@workspace.DatabaseName"
                                  E2eePassphrase="@workspace.E2eePassphrase" />
                </div>
            </FluentStack>
        </FluentTab>

        <FluentTab Label="Members" Id="tab-members" Icon="@(new Icons.Regular.Size20.People())">
            <div style="margin-top: 1rem;">
                <MemberList WorkspaceId="@Id" CurrentUsername="@username"
                            Security="@workspace.Members" />
            </div>
        </FluentTab>

        <FluentTab Label="Getting Started" Id="tab-guide" Icon="@(new Icons.Regular.Size20.BookOpen())">
            <div style="margin-top: 1rem; max-width: 600px;">
                <ol style="padding-left: 1.25rem;">
                    <li>Install the <strong>Obsidian LiveSync</strong> plugin in your vault.</li>
                    <li>Click <strong>Generate Setup URI</strong> on the Setup tab.</li>
                    <li>Open the plugin settings and choose <strong>Use the copied setup URI</strong>.</li>
                    <li>Copy the Setup URI and paste it when prompted.</li>
                    <li>When asked for the <strong>Setup URI passphrase</strong>, type the passphrase shown (do not copy it).</li>
                    <li>Your vault will begin syncing automatically.</li>
                </ol>
            </div>
        </FluentTab>
    </FluentTabs>
}

@code {
    [Parameter] public string Id { get; set; } = default!;

    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState> AuthStateTask { get; set; } = default!;

    private string activeTab = "tab-setup";
    private bool? found;
    private WorkspaceInfo? workspace;
    private string username = "";
    private string sub = "";

    protected override async Task OnInitializedAsync()
    {
        username = AuthStateTask.Result.User.FindFirst("preferred_username")!.Value;
        sub = AuthStateTask.Result.User.FindFirst("sub")!.Value;

        await WorkspaceSvc.EnsureCurrentUserAsync(username, sub);

        workspace = await WorkspaceSvc.GetAsync(Id);
        if (workspace is null || !workspace.Members.IsMember(username))
        {
            found = false;
            return;
        }

        found = true;
    }


}
