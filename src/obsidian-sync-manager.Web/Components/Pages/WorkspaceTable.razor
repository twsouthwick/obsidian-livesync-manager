<FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="16" VerticalGap="16">
    @foreach (var workspace in Workspaces)
    {
        <FluentCard Style="width: 280px;">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <FluentAnchor Href="@($"workspaces/{workspace.Id}")" Appearance="Appearance.Hypertext"
                              Style="font-size: 1.1rem; font-weight: 600;">
                    @workspace.Name
                </FluentAnchor>
                <FluentLabel Color="Color.Neutral" Style="font-size: 0.85rem;">
                    @(workspace.Members.Admins.Names.Union(workspace.Members.Members.Names).Count()) members
                </FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="4">
                    <FluentAnchor Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size16.Settings())"
                                  Href="@($"workspaces/{workspace.Id}")">
                        Details
                    </FluentAnchor>
                    <FluentButton Appearance="Appearance.Stealth" Size="ButtonSize.Small"
                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                  @onclick="() => OnDelete.InvokeAsync(workspace)"
                                  Style="color: var(--error);">
                        Delete
                    </FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    [Parameter, EditorRequired] public List<WorkspaceInfo> Workspaces { get; set; } = default!;
    [Parameter] public EventCallback<WorkspaceInfo> OnDelete { get; set; }
}
