<FluentCard Style="padding: 1.5rem; height: 100%;">
    <h5 style="margin-top: 0;">Connection Info</h5>
    <div style="display: grid; grid-template-columns: auto 1fr; gap: 0.5rem 1rem;">
        <FluentLabel Weight="FontWeight.Bold">Database</FluentLabel>
        <code>@DatabaseName</code>
        <FluentLabel Weight="FontWeight.Bold">CouchDB User</FluentLabel>
        <code>@CouchDbUsername</code>
    </div>
</FluentCard>

@code {
    [Parameter, EditorRequired] public string DatabaseName { get; set; } = default!;
    [Parameter, EditorRequired] public string CouchDbUsername { get; set; } = default!;
}
