@page "/workspaces"
@page "/"
@inject WorkspaceService WorkspaceSvc
@inject IToastService ToastService
@inject IDialogService DialogService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Workspaces</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween"
             VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 1.5rem;">
    <h1 style="margin: 0;">Workspaces</h1>
    <FluentButton Appearance="Appearance.Accent" @onclick="() => showCreateForm = true" Disabled="@showCreateForm"
                  IconStart="@(new Icons.Regular.Size20.Add())">
        New Workspace
    </FluentButton>
</FluentStack>

@if (showCreateForm)
{
    <CreateWorkspaceForm OnCreated="OnWorkspaceCreated" OnCancel="() => showCreateForm = false" />
}

@if (workspaces is null)
{
    <FluentProgress />
}
else if (workspaces.Count == 0 && !showCreateForm)
{
    <EmptyState Title="No workspaces yet" Icon="@(new Icons.Regular.Size48.Folder())">
        Create a workspace to start syncing your Obsidian vault.
    </EmptyState>
}
else
{
    <WorkspaceTable Workspaces="workspaces" OnDelete="DeleteWorkspace" />
}

@code {
    private List<WorkspaceInfo>? workspaces;
    private bool showCreateForm;

    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState> AuthStateTask { get; set; } = default!;

    private string Username => AuthStateTask.Result.User.FindFirst("preferred_username")!.Value;
    private string Sub => AuthStateTask.Result.User.FindFirst("sub")!.Value;

    protected override async Task OnInitializedAsync()
    {
        await WorkspaceSvc.EnsureCurrentUserAsync(Username, Sub);
        workspaces = await WorkspaceSvc.GetAllAsync(Username).OrderBy(w => w.Name).ToListAsync();
    }

    private async Task OnWorkspaceCreated()
    {
        showCreateForm = false;
        workspaces = await WorkspaceSvc.GetAllAsync(Username).OrderBy(w => w.Name).ToListAsync();
        ToastService.ShowSuccess("Workspace created successfully.");
    }

    private async Task DeleteWorkspace(WorkspaceInfo workspace)
    {
        var dialog = await DialogService.ShowConfirmationAsync(
            $"Delete workspace \"{workspace.Name}\"? This will permanently remove the CouchDB database and all synced data.",
            "Delete", "Cancel", "Delete Workspace");

        var result = await dialog.Result;
        if (result.Cancelled) return;

        if (await WorkspaceSvc.DeleteAsync(workspace.Id, Username))
        {
            workspaces?.Remove(workspace);
            ToastService.ShowSuccess($"Workspace \"{workspace.Name}\" deleted.");
        }
        else
        {
            ToastService.ShowError($"Failed to delete workspace \"{workspace.Name}\".");
        }
    }
}
