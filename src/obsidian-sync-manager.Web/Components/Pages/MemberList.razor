@rendermode InteractiveServer
@using System.Collections.Immutable
@using Swick.Obsidian.SyncManager.Web.CouchDb

@if (AllNames.Count > 0)
{
    <ul class="list-group mb-3">
        @foreach (var name in AllNames)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                    <span class="bi bi-person me-1" aria-hidden="true"></span>
                    @name
                    @if (Security.IsAdmin(name))
                    {
                        <span class="badge bg-primary ms-1">admin</span>
                    }
                    @if (name == CurrentUsername)
                    {
                        <span class="badge bg-secondary ms-1">you</span>
                    }
                </span>
                @if (name != CurrentUsername)
                {
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => OnRemove.InvokeAsync(name)">
                        <span class="bi bi-x-lg" aria-hidden="true"></span> Remove
                    </button>
                }
            </li>
        }
    </ul>
}

<div class="input-group" style="max-width: 400px;">
    <input type="text" class="form-control" placeholder="Username to add" @bind="newUsername"
        @bind:event="oninput" disabled="@adding" />
    <button class="btn btn-outline-primary" type="button" @onclick="HandleAdd" disabled="@(adding || string.IsNullOrWhiteSpace(newUsername))">
        @(adding ? "Adding..." : "Add Member")
    </button>
</div>

@code {
    [Parameter, EditorRequired] public CouchDbSecurityRecord Security { get; set; } = default!;
    [Parameter, EditorRequired] public string CurrentUsername { get; set; } = default!;
    [Parameter] public EventCallback<string> OnAdd { get; set; }
    [Parameter] public EventCallback<string> OnRemove { get; set; }

    private ImmutableList<string> AllNames => Security.Admins.Names.Union(Security.Members.Names).ToImmutableList();

    private string? newUsername;
    private bool adding;

    private async Task HandleAdd()
    {
        if (string.IsNullOrWhiteSpace(newUsername)) return;
        adding = true;
        await OnAdd.InvokeAsync(newUsername.Trim());
        newUsername = null;
        adding = false;
    }
}
