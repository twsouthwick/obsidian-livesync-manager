<FluentCard Style="padding: 1.5rem; height: 100%;">
    <h5 style="margin-top: 0;">Setup URI</h5>

    @if (!string.IsNullOrEmpty(SetupUri))
    {
        <p style="color: var(--neutral-foreground-hint);">
            Use this URI to configure Obsidian LiveSync in your vault.
        </p>

        <FluentMessageBar Title="URI Passphrase" Intent="MessageIntent.Warning" Style="margin-bottom: 1rem;">
            <code style="user-select: all; font-size: 1rem;">@UriPassphrase</code>
            <br />
            <small>Type this passphrase when prompted in Obsidian. Do not copy it — type it manually for security.</small>
        </FluentMessageBar>

        <QrCode Uri="@SetupUri" Caption="Scan with your phone to open in Obsidian" />

        <div style="background: var(--neutral-layer-2); border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; padding: 0.75rem; max-height: 6rem; overflow: auto; margin-top: 1rem;">
            <code style="font-size: 0.8rem; word-break: break-all;">@SetupUri</code>
        </div>

        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top: 1rem;">
            <CopyButton Text="@SetupUri" Label="Copy URI" />
            <FluentAnchor Href="@SetupUri" Appearance="Appearance.Accent">
                <FluentIcon Value="@(new Icons.Regular.Size16.Open())" Slot="start" /> Open in Obsidian
            </FluentAnchor>
            <FluentButton Appearance="Appearance.Outline" @onclick="OnReset"
                          IconStart="@(new Icons.Regular.Size16.ArrowCounterclockwise())">
                Regenerate
            </FluentButton>
        </FluentStack>
    }
</FluentCard>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = default!;
    [Parameter, EditorRequired] public string Username { get; set; } = default!;
    [Parameter, EditorRequired] public string Sub { get; set; } = default!;
    [Parameter, EditorRequired] public string WorkspaceId { get; set; } = default!;
    [Parameter, EditorRequired] public string DatabaseName { get; set; } = default!;
    [Parameter, EditorRequired] public string E2eePassphrase { get; set; } = default!;

    [Inject] private WorkspaceService WorkspaceSvc { get; set; } = default!;

    private string? SetupUri;
    private string? UriPassphrase;

    protected override async Task OnParametersSetAsync()
    {
        var result = WorkspaceSvc.GenerateSetupUri(Username, Sub, WorkspaceId, DatabaseName, E2eePassphrase);
        SetupUri = result.Uri;
        UriPassphrase = result.UriPassphrase;
     }

    private void OnReset()
    {
        SetupUri = null;
        UriPassphrase = null;
    }
}
